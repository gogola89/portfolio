# Django Portfolio - Production Environment Template
# Copy this to .env.production for VPS deployment

# SECURITY
SECRET_KEY=generate-a-strong-secret-key-here-use-openssl-rand-hex-50
DEBUG=False

# Hosts
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-vps-ip

# Database (PostgreSQL for production)
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=use-a-strong-password-here
DB_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Ports
HTTP_PORT=80
HTTPS_PORT=443

# Email (optional - for contact form notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com
